# Radio Delay System Configuration

# The source URL of the radio stream to record
SOURCE_URL="https://a11.asurahosting.com:8970/radio.mp3"

# Icecast configuration
ICECAST_PORT=8000
ICECAST_PASSWORD="hackme"
ICECAST_BIND_ADDRESS="0.0.0.0"

# Application directory
BASE_DIR="/opt/radio-delay"

# Recording settings
RECORDINGS_DIR="${BASE_DIR}/recordings"
MAP_DIR="${BASE_DIR}/map"
SEGMENT_TIME=3600 # 1 hour
RETENTION_MINS=2880 # 48 hours

# Audio Quality and Bitrate Settings
RECORD_BITRATE="192k"       # Bitrate for recorded MP3 segments (e.g., 128k, 192k, 256k, 320k)
OUT_MP3_BITRATE="192"       # Icecast output MP3 bitrate in kbps (e.g., 128, 192, 320)
OUT_AAC_BITRATE="192k"      # Icecast output AAC bitrate (e.g., 64k, 96k, 128k, 320k)

